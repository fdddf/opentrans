# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=xcstrings_user
DB_PASSWORD=change_this_password
DB_NAME=xcstrings_translator
DB_SSL_MODE=disable

# Alternative: Use DATABASE_URL instead of individual DB_* variables
# DATABASE_URL=postgres://xcstrings_user:change_this_password@localhost:5432/xcstrings_translator?sslmode=disable

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production

# Application Configuration
BASE_URL=http://localhost:8080

# Email Configuration (for user activation)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com

# Stripe Configuration (for subscriptions)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Apple Connect Configuration (optional, for App Store Connect integration)
APPLE_ISSUER_ID=your-issuer-id
APPLE_KEY_ID=your-key-id
APPLE_PRIVATE_KEY_PATH=/path/to/private/key.p8